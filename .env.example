# REQUIRED: Path to your root lecture folder (subdirectories = modules)
WATCH_FOLDER=C:\Path\To\Your\Study\Materials

# Embedding provider: "ollama" (default) or "huggingface"
# EMBEDDING_PROVIDER=ollama

# If using Hugging Face Inference API for embeddings
# HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# LLM (NVIDIA NIM)
# NVIDIA_API_KEY=nvapi-...

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# API server port
# API_PORT=8000
